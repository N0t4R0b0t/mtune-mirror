# Local override for mesa-amber (atom / i686) — NEEDS A REAL PKGBUILD.
#
# mesa-amber is the frozen (21.3.x) fork of mesa that keeps the classic hardware
# drivers alive, and is the only way to get accelerated GL on the GMA950 (gen3).
# It is NOT in Arch's repos and no longer in the AUR — it is maintained by
# archlinux32 (installed on the target as 21.3.9-6.2, packager TasosSah). The
# generic upstream fetch (Arch GitLab) therefore cannot build it; it needs this
# local override so pkgmirror builds it tuned with -march=atom.
#
# TO POPULATE (one of):
#   * from the archlinux32 build tree: obtain their mesa-amber PKGBUILD + files and
#     drop them in this directory (git.archlinux32.org / their package sources);
#   * or fetch the archlinux32 source package (…/sources/mesa-amber-*.src.tar.gz)
#     from an archlinux32 mirror and copy its PKGBUILD + patches here.
#
# Until then this package fail-and-skips on every atom build sweep (logged),
# without blocking the rest of the group. It is the one essentials-atom package
# that needs manual sourcing; the others (xf86-video-intel, pango, gdk-pixbuf2,
# sdl2) build automatically from the upstream Arch PKGBUILDs (--ignorearch).

pkgname=mesa-amber
